---
---

<button data-theme-toggle class="flex items-center gap-2 bg-bg-surface border border-stroke rounded text-fg-muted px-2 py-1 text-xs font-mono cursor-pointer hover:text-fg transition-colors">
  <!-- Sun icon (shown in dark mode, hidden in light mode) -->
  <svg
    data-icon-sun
    xmlns="http://www.w3.org/2000/svg"
    width="13"
    height="13"
    viewBox="0 0 13 13"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="dark:hidden"
  >
    <circle cx="6.5" cy="6.5" r="2.5" />
    <line x1="6.5" y1="1" x2="6.5" y2="2" />
    <line x1="6.5" y1="11" x2="6.5" y2="12" />
    <line x1="1" y1="6.5" x2="2" y2="6.5" />
    <line x1="11" y1="6.5" x2="12" y2="6.5" />
    <line x1="2.5" y1="2.5" x2="3.2" y2="3.2" />
    <line x1="9.8" y1="9.8" x2="10.5" y2="10.5" />
    <line x1="2.5" y1="10.5" x2="3.2" y2="9.8" />
    <line x1="9.8" y1="3.2" x2="10.5" y2="2.5" />
  </svg>

  <!-- Moon icon (shown in light mode, hidden in dark mode) -->
  <svg
    data-icon-moon
    xmlns="http://www.w3.org/2000/svg"
    width="13"
    height="13"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="hidden dark:block"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>

  <!-- Label (shows 'light' in dark mode, 'dark' in light mode) -->
  <span data-theme-label class="dark:inline hidden">light</span>
  <span data-theme-label class="hidden dark:hidden">dark</span>
</button>

<script>
  (function() {
    // Initialize all theme toggles on the page
    function initThemeToggle(button: Element) {
      if (!(button instanceof HTMLElement)) return;
      const sunIcon = button.querySelector('[data-icon-sun]');
      const moonIcon = button.querySelector('[data-icon-moon]');
      const label = button.querySelector('[data-theme-label]');

      function syncUI() {
        const isDark = document.documentElement.classList.contains('dark');
        if (sunIcon) {
          sunIcon.classList.toggle('hidden', !isDark);
        }
        if (moonIcon) {
          moonIcon.classList.toggle('hidden', isDark);
        }
        if (label) {
          label.textContent = isDark ? 'light' : 'dark';
        }
      }

      button.addEventListener('click', () => {
        const isDark = document.documentElement.classList.contains('dark');

        if (isDark) {
          document.documentElement.classList.remove('dark');
          localStorage.setItem('theme', 'light');
        } else {
          document.documentElement.classList.add('dark');
          localStorage.setItem('theme', 'dark');
        }

        // Sync all toggles
        document.querySelectorAll('[data-theme-toggle]').forEach((toggle) => {
          const sun = toggle.querySelector('[data-icon-sun]');
          const moon = toggle.querySelector('[data-icon-moon]');
          const lbl = toggle.querySelector('[data-theme-label]');

          if (sun) sun.classList.toggle('hidden', !document.documentElement.classList.contains('dark'));
          if (moon) moon.classList.toggle('hidden', document.documentElement.classList.contains('dark'));
          if (lbl) lbl.textContent = document.documentElement.classList.contains('dark') ? 'light' : 'dark';
        });

        // Close mobile menu if available
        if (typeof (window as any).closeMenu === 'function') {
          (window as any).closeMenu();
        }
      });

      // Sync UI on load
      syncUI();
    }

    // Initialize all theme toggles on DOMContentLoaded
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('[data-theme-toggle]').forEach(initThemeToggle);
      });
    } else {
      // DOM is already ready
      document.querySelectorAll('[data-theme-toggle]').forEach(initThemeToggle);
    }
  })();
</script>
